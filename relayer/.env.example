# Relayer Private Key (for transaction signing)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Avalanche Fuji RPC URL
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Contract address (deployed ReflexParametricEscrow)
ESCROW_CONTRACT_ADDRESS=0xYOUR_ESCROW_CONTRACT_ADDRESS

# Aviationstack API Key (get from https://aviationstack.com/)
AVIATIONSTACK_API_KEY=

# Polling interval in seconds (default: 60)
POLL_INTERVAL_SECONDS=60

# ── Chainlink Configuration ──
CHAINLINK_SUBSCRIPTION_ID=YOUR_SUBSCRIPTION_ID_NUMBER
CHAINLINK_ROUTER=0xA9d587a00A31A52Ed70D6026794a8FC5E2F5dCb0 # Fuji Testnet
CHAINLINK_DON_ID=fun-avalanche-fuji-1 # Fuji Testnet
CHAINLINK_GAS_LIMIT=300000
FLIGHTAWARE_API_KEY=
