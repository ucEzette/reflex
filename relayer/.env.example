# Relayer Private Key (for transaction signing)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Avalanche Fuji RPC URL
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Contract address (deployed ReflexParametricEscrow)
ESCROW_CONTRACT_ADDRESS=0xYOUR_ESCROW_CONTRACT_ADDRESS

# Teleporter address (deployed MockTeleporterMessenger or real Teleporter)
TELEPORTER_ADDRESS=0xYOUR_TELEPORTER_ADDRESS

# Reclaim Protocol App ID + Secret
RECLAIM_APP_ID=YOUR_RECLAIM_APP_ID
RECLAIM_APP_SECRET=YOUR_RECLAIM_APP_SECRET

# FlightAware AeroAPI Key
FLIGHTAWARE_API_KEY=YOUR_FLIGHTAWARE_API_KEY

# Polling interval in seconds (default: 60)
POLL_INTERVAL_SECONDS=60
